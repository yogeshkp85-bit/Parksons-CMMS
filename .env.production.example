# =========================================================================
# BACKEND PRODUCTION PRESETS
# =========================================================================
PORT=5000
NODE_ENV=production

# Database configuration (Replace values with secure credentials)
POSTGRES_DB=cmms_db
POSTGRES_USER=cmms_prod_user
POSTGRES_PASSWORD=replace_this_with_a_secure_long_password
DATABASE_URL=postgresql://cmms_prod_user:replace_this_with_a_secure_long_password@postgres:5432/cmms_db

# Security Secrets (Generate strong cryptographic keys)
JWT_SECRET=replace_this_with_a_secure_long_jwt_secret_key
REFRESH_SECRET=replace_this_with_a_secure_long_refresh_secret_key

# =========================================================================
# FRONTEND PRODUCTION PRESETS
# =========================================================================
# Points frontend to route through the Nginx reverse proxy
VITE_API_URL=/api
VITE_SOCKET_URL=/
