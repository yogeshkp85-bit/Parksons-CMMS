datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =========================================================================
// AUTHENTICATION & USERS
// =========================================================================

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  passwordHash String
  phone        String?
  roleId       String    @db.Uuid
  plantId      String?   @db.Uuid
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  role  Role   @relation(fields: [roleId], references: [id])
  plant Plant? @relation(fields: [plantId], references: [id])

  breakdownsCreated  BreakdownLog[] @relation("CreatedByRelation")
  breakdownsApproved BreakdownLog[] @relation("ApprovedByRelation")
  pmCompleted        PmSchedule[]   @relation("PmCompletedBy")
  auditLogs          AuditLog[]
  sysAuditLogs       SysAuditLog[]

  @@map("users")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  code        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  code      String    @unique
  module    String
  action    String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// =========================================================================
// MASTER TABLES
// =========================================================================

model Plant {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  code      String    @unique
  address   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users           User[]
  departments     Department[]
  breakdownLogs   BreakdownLog[]
  holidayCalendar HolidayCalendar[]

  @@map("plants")
}

model Department {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  code      String
  plantId   String    @db.Uuid
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  plant         Plant          @relation(fields: [plantId], references: [id])
  sections      Section[]
  breakdownLogs BreakdownLog[]

  @@unique([plantId, code])
  @@map("departments")
}

model Section {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  code         String
  departmentId String    @db.Uuid
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  department    Department     @relation(fields: [departmentId], references: [id])
  units         Unit[]
  machines      Machine[]
  breakdownLogs BreakdownLog[]
  pmTasks       PmTask[]

  @@unique([departmentId, code])
  @@map("sections")
}

model Unit {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  code      String
  sectionId String    @db.Uuid
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  section       Section        @relation(fields: [sectionId], references: [id])
  machines      Machine[]
  breakdownLogs BreakdownLog[]

  @@unique([sectionId, code])
  @@map("units")
}

model MachineCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  code      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  machines Machine[]
  pmTasks  PmTask[]

  @@map("machine_categories")
}

model Machine {
  id                String    @id @default(uuid()) @db.Uuid
  machineId         String    @unique
  name              String
  machineCategoryId String    @map("machine_category_id") @db.Uuid
  unitId            String?   @map("unit_id") @db.Uuid
  sectionId         String    @map("section_id") @db.Uuid
  parentMachineId   String?   @map("parent_machine_id") @db.Uuid
  isSubAssembly     Boolean   @default(false) @map("is_sub_assembly")
  oem               String?
  model             String?
  serialNumber      String?
  installationDate  DateTime? @map("installation_date")
  status            String    @default("ACTIVE")
  criticality       String    @default("MEDIUM")
  imageUrl          String?   @map("image_url")
  qrCode            String?   @map("qr_code")
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  category      MachineCategory @relation(fields: [machineCategoryId], references: [id])
  unit          Unit?           @relation(fields: [unitId], references: [id])
  section       Section         @relation(fields: [sectionId], references: [id])
  parentMachine Machine?        @relation("MachineHierarchy", fields: [parentMachineId], references: [id])
  subMachines   Machine[]       @relation("MachineHierarchy")
  subAssemblies SubAssembly[]
  breakdowns    BreakdownLog[]
  pmSchedules   PmSchedule[]

  @@map("machines")
}

model SubAssembly {
  id          String    @id @default(uuid()) @db.Uuid
  machineId   String    @map("machine_id") @db.Uuid
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  machine    Machine     @relation(fields: [machineId], references: [id])
  components Component[]

  @@map("sub_assemblies")
}

model Component {
  id            String    @id @default(uuid()) @db.Uuid
  subAssemblyId String    @map("sub_assembly_id") @db.Uuid
  name          String
  description   String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  subAssembly SubAssembly @relation(fields: [subAssemblyId], references: [id])

  @@map("components")
}

// =========================================================================
// CATEGORY MASTERS & AUX TABLES
// =========================================================================

model BreakdownCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  breakdowns BreakdownLog[]

  @@map("breakdown_categories")
}

model ProblemCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  breakdowns BreakdownLog[]

  @@map("problem_categories")
}

model RootCauseCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  breakdowns BreakdownLog[]

  @@map("root_cause_categories")
}

model ActionTakenCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  breakdowns BreakdownLog[]

  @@map("action_taken_categories")
}

model ShiftMaster {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  code      String    @unique
  startTime String
  endTime   String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  breakdowns BreakdownLog[]

  @@map("shift_masters")
}

model HolidayCalendar {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  date      DateTime
  plantId   String    @db.Uuid
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  plant Plant @relation(fields: [plantId], references: [id])

  @@unique([plantId, date])
  @@map("holiday_calendars")
}

model Vendor {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  contactPerson String?   @map("contact_person")
  email         String?
  phone         String?
  address       String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  spares SparePart[]

  @@map("vendors")
}

model SparePart {
  id          String    @id @default(uuid()) @db.Uuid
  partNumber  String    @unique @map("part_number")
  name        String
  description String?
  uom         String    @default("PCS")
  unitPrice   Float     @default(0.0) @map("unit_price")
  vendorId    String?   @db.Uuid
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  vendor          Vendor?                  @relation(fields: [vendorId], references: [id])
  breakdownSpares BreakdownSparePartUsed[]

  @@map("spare_parts")
}

model PmFrequencyMaster {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  code         String    @unique
  intervalDays Int       @map("interval_days")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  pmTasks PmTask[]

  @@map("pm_frequency_masters")
}

// =========================================================================
// BREAKDOWN MANAGEMENT MODULE
// =========================================================================

model BreakdownLog {
  id                     String    @id @default(uuid()) @db.Uuid
  breakdownNumber        String    @unique @map("breakdown_number")
  plantId                String    @map("plant_id") @db.Uuid
  departmentId           String    @map("department_id") @db.Uuid
  sectionId              String    @map("section_id") @db.Uuid
  machineId              String    @map("machine_id") @db.Uuid
  unitId                 String?   @map("unit_id") @db.Uuid
  date                   DateTime
  shiftId                String    @map("shift_id") @db.Uuid
  startTime              DateTime  @map("time_start")
  endTime                DateTime? @map("time_end")
  durationMin            Int?      @map("duration_min")
  categoryId             String    @map("category_id") @db.Uuid
  problemCategoryId      String    @map("problem_category_id") @db.Uuid
  problemDescription     String    @map("description")
  actionTakenCategoryId  String?   @map("action_taken_category_id") @db.Uuid
  actionTakenDescription String?   @map("action_taken")
  rootCauseCategoryId    String?   @map("root_cause_category_id") @db.Uuid
  rootCauseDescription   String?   @map("root_cause")
  remarks                String?
  attendedBy             String?   @map("attended_by")
  additionalTeam         String?   @map("additional_team")   // comma-separated co-worker names
  submittedBy            String?   @map("submitted_by")
  problemReported        String?   @map("problem_reported")  // what operator reported
  spareConsumed          String?   @map("spare_consumed")    // free text; links to spare module later
  endDate                DateTime? @map("end_date")          // for multi-day breakdowns
  downtimeHours          Float?    @map("downtime_hours")
  manpowerCount          Int?      @default(1) @map("manpower_count")
  imageUrl               String?   @map("image_url")
  status                 String    @default("PENDING_REVIEW")
  createdByUserId        String    @map("created_by") @db.Uuid
  approvedByUserId       String?   @map("approved_by") @db.Uuid
  approvedAt             DateTime? @map("approved_date")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  plant               Plant                @relation(fields: [plantId], references: [id])
  department          Department           @relation(fields: [departmentId], references: [id])
  section             Section              @relation(fields: [sectionId], references: [id])
  machine             Machine              @relation(fields: [machineId], references: [id])
  unit                Unit?                @relation(fields: [unitId], references: [id])
  shift               ShiftMaster          @relation(fields: [shiftId], references: [id])
  category            BreakdownCategory    @relation(fields: [categoryId], references: [id])
  problemCategory     ProblemCategory      @relation(fields: [problemCategoryId], references: [id])
  actionTakenCategory ActionTakenCategory? @relation(fields: [actionTakenCategoryId], references: [id])
  rootCauseCategory   RootCauseCategory?   @relation(fields: [rootCauseCategoryId], references: [id])
  createdBy           User                 @relation("CreatedByRelation", fields: [createdByUserId], references: [id])
  approvedBy          User?                @relation("ApprovedByRelation", fields: [approvedByUserId], references: [id])

  sparesUsed BreakdownSparePartUsed[]

  @@map("breakdown_logs")
}

model BreakdownSparePartUsed {
  id             String   @id @default(uuid()) @db.Uuid
  breakdownLogId String   @map("breakdown_log_id") @db.Uuid
  sparePartId    String   @map("spare_part_id") @db.Uuid
  quantity       Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  breakdownLog BreakdownLog @relation(fields: [breakdownLogId], references: [id], onDelete: Cascade)
  sparePart    SparePart    @relation(fields: [sparePartId], references: [id])

  @@unique([breakdownLogId, sparePartId])
  @@map("breakdown_spares_used")
}

// =========================================================================
// PM MODULE
// =========================================================================

model PmTask {
  id                String    @id @default(uuid()) @db.Uuid
  name              String
  description       String?
  machineCategoryId String?   @map("machine_category_id") @db.Uuid
  frequencyId       String    @map("frequency_id") @db.Uuid
  checkpoints       String
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  plantId           String?   @map("plant_id") @db.Uuid
  departmentId      String?   @map("department_id") @db.Uuid
  sectionId         String?   @map("section_id") @db.Uuid
  machineTypeId     String?   @map("machine_type_id") @db.Uuid
  machineId         String?   @map("machine_id") @db.Uuid
  unitId            String?   @map("unit_id") @db.Uuid

  estimatedTime     Float?    @map("estimated_time")
  requiredSkill     String?   @map("required_skill")
  safetyInstruction String?   @map("safety_instruction")
  lubricationPoint  String?   @map("lubrication_point")
  spareRequired     String?   @map("spare_required")
  sop               String?
  photoUrl          String?   @map("photo_url")

  category    MachineCategory?  @relation(fields: [machineCategoryId], references: [id])
  frequency   PmFrequencyMaster @relation(fields: [frequencyId], references: [id])
  plant       MstPlant?         @relation(fields: [plantId], references: [plantId])
  department  MstDepartment?    @relation(fields: [departmentId], references: [deptId])
  section     Section?          @relation(fields: [sectionId], references: [id])
  machineType MstMachineType?   @relation(fields: [machineTypeId], references: [machineTypeId])
  machine     MstMachine?       @relation(fields: [machineId], references: [machineId])
  unit        MstMachineUnit?   @relation(fields: [unitId], references: [unitId])

  schedules PmSchedule[]

  @@map("pm_tasks")
}

model PmSchedule {
  id                String    @id @default(uuid()) @db.Uuid
  machineId         String    @map("machine_id") @db.Uuid
  pmTaskId          String    @map("pm_task_id") @db.Uuid
  dueDate           DateTime  @map("due_date")
  status            String    @default("PENDING")
  completedAt       DateTime? @map("completed_at")
  completedByUserId String?   @map("completed_by") @db.Uuid
  completionRemarks String?
  checkpointsResult Json?
  imageUrl          String?   @map("image_url")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  machine     Machine @relation(fields: [machineId], references: [id])
  pmTask      PmTask  @relation(fields: [pmTaskId], references: [id])
  completedBy User?   @relation("PmCompletedBy", fields: [completedByUserId], references: [id])

  @@map("pm_schedules")
}

// =========================================================================
// SYSTEM SERVICES: AUDIT TRAIL
// =========================================================================

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  module    String
  action    String
  targetId  String?  @map("target_id") @db.Uuid
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
// =========================================================================
// MASTER ADDITIONS — FINANCIAL YEAR & TECHNICIAN
// =========================================================================

model FinancialYear {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique   // e.g. "2024-25"
  label       String              // e.g. "FY 2024-25"
  startDate   DateTime  @map("start_date")   // Apr 1 YYYY
  endDate     DateTime  @map("end_date")     // Mar 31 YYYY+1
  isCurrent   Boolean   @default(false) @map("is_current")
  isActive    Boolean   @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("financial_years")
}

model Technician {
  id           String    @id @default(uuid()) @db.Uuid
  code         String    @unique   // e.g. "TECH-001"
  name         String
  designation  String?
  department   String?
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@map("technicians")
}

// =========================================================================
// PHASE 6 PLACEHOLDERS
// =========================================================================

model MachineHistory {
  id        String   @id @default(uuid()) @db.Uuid
  machineId String   @db.Uuid
  event     String
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("machine_history")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @default("default") @map("tenant_id")
  userEmail String   @map("user_email")
  type      String
  title     String
  message   String
  refId     String?  @map("ref_id")
  machine   String?
  remarks   String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userEmail, isRead])
  @@index([tenantId])
  @@map("notifications")
}


model Report {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  type      String
  generated DateTime @default(now())
  url       String?

  @@map("reports")
}

model Attachment {
  id         String   @id @default(uuid()) @db.Uuid
  entityId   String   @db.Uuid
  entityType String
  url        String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("attachments")
}

model Configuration {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique
  value String

  @@map("configurations")
}
// =========================================================================
// PHASE 7.1: OPTION 1 FLAT TABLES (SHEET MIRRORS)
// =========================================================================

model RawData {
  id             String    @id @default(uuid()) @db.Uuid
  Timestamp      DateTime?
  Ref_ID         String    @unique
  Date           String?
  Shift          String?
  Machine_Type   String?
  Machine_Name   String?
  Unit           String?
  Problem_Type   String?
  Category       String?
  Description    String?
  Action_Taken   String?
  Root_Cause     String?
  Time_Start     String?
  Time_End       String?
  Duration_Min   Float?
  Attended_By    String?
  Submitted_By   String?
  Remarks        String?
  Status         String?   @default("PENDING_REVIEW")

  @@map("raw_data")
}

model MachineData {
  id           String @id @default(uuid()) @db.Uuid
  machine_type String
  machine_name String @unique
  units        String

  @@map("machine_data")
}

model AdminUsers {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  email       String  @unique
  password    String
  level       String
  permissions Json?

  @@map("admin_users")
}

model FinalData {
  id                 String  @id @default(uuid()) @db.Uuid
  Ref_ID             String  @unique
  Month_Year         String?
  Date               String?
  Shift              String?
  Machine_Type       String?
  Machine_Name       String?
  Unit               String?
  Problem_Type       String?
  Category           String?
  Description        String?
  Action_Taken       String?
  Time_Start         String?
  Time_End           String?
  Minutes            Float?
  BD_Flag            Int?
  Available_Time_Min Float?
  Attended_By        String?

  @@map("final_data")
}

model HistoricalKPI {
  id              String  @id @default(uuid()) @db.Uuid
  FY              String?
  Month           String?
  Machine         String?
  Available_Time  Float?
  Breakdown_Time  Float?
  Breakdown_Count Int?
  Uptime          Float?
  MTTR            Float?
  MTBF            Float?
  Availability    Float?

  @@map("historical_kpi")
}

// =========================================================================
// PHASE 15.2A: SYNCHRONIZATION LOGS
// =========================================================================

model SyncLog {
  id               String    @id @default(uuid()) @db.Uuid
  entityName       String    @map("entity_name")
  recordsProcessed Int       @default(0) @map("records_processed")
  recordsInserted  Int       @default(0) @map("records_inserted")
  recordsUpdated   Int       @default(0) @map("records_updated")
  status           String
  errorMessage     String?   @map("error_message")
  startedAt        DateTime  @default(now()) @map("started_at")
  completedAt      DateTime? @map("completed_at")

  @@map("sync_logs")
}

// =========================================================================
// MASTER DATA MANAGEMENT (MDM) MODULE
// =========================================================================

model MstPlant {
  plantId   String    @id @default(uuid()) @db.Uuid @map("plant_id")
  plantCode String    @unique @map("plant_code")
  plantName String    @map("plant_name")
  city      String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  departments MstDepartment[]
  machines    MstMachine[]
  pmTasks     PmTask[]

  @@map("mst_plant")
}

model MstDepartment {
  deptId    String    @id @default(uuid()) @db.Uuid @map("dept_id")
  deptCode  String    @map("dept_code")
  deptName  String    @map("dept_name")
  plantId   String    @db.Uuid @map("plant_id")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  plant        MstPlant         @relation(fields: [plantId], references: [plantId])
  machineTypes MstMachineType[]
  pmTasks      PmTask[]

  @@map("mst_department")
}

model MstMachineType {
  machineTypeId String    @id @default(uuid()) @db.Uuid @map("machine_type_id")
  typeCode      String    @map("type_code")
  typeName      String    @map("type_name")
  deptId        String    @db.Uuid @map("dept_id")
  sortOrder     Int       @default(0) @map("sort_order")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  department MstDepartment @relation(fields: [deptId], references: [deptId])
  machines   MstMachine[]
  pmTasks    PmTask[]

  @@map("mst_machine_type")
}

model MstMachine {
  machineId     String    @id @default(uuid()) @db.Uuid @map("machine_id")
  machineCode   String    @map("machine_code")
  machineName   String    @map("machine_name")
  machineTypeId String    @db.Uuid @map("machine_type_id")
  plantId       String    @db.Uuid @map("plant_id")
  criticality   String?
  serialNo      String?   @map("serial_no")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  machineType MstMachineType   @relation(fields: [machineTypeId], references: [machineTypeId])
  plant       MstPlant         @relation(fields: [plantId], references: [plantId])
  units       MstMachineUnit[]
  pmTasks     PmTask[]

  @@map("mst_machine")
}

model MstMachineUnit {
  unitId       String    @id @default(uuid()) @db.Uuid @map("unit_id")
  unitCode     String    @map("unit_code")
  unitName     String    @map("unit_name")
  machineId    String    @db.Uuid @map("machine_id")
  parentUnitId String?   @db.Uuid @map("parent_unit_id")
  position     Int?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  machine    MstMachine      @relation(fields: [machineId], references: [machineId])
  parentUnit MstMachineUnit? @relation("UnitHierarchy", fields: [parentUnitId], references: [unitId])
  subUnits   MstMachineUnit[] @relation("UnitHierarchy")
  pmTasks    PmTask[]

  @@map("mst_machine_unit")
}

