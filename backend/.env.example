PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
JWT_SECRET=secret

# ==========================================
# EMAIL CONFIGURATION (Phase 5 — Daily Report)
# ==========================================
# Use Gmail with an App Password (not your regular Gmail password).
# To generate: Google Account → Security → 2-Step Verification → App Passwords
# Choose "Mail" and "Windows Computer", copy the 16-character password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yogeshkp85@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Comma-separated recipient list for the 9AM daily report email
REPORT_EMAILS=yogeshkp85@gmail.com,engg.cn@parksonspackaging.com

# ==========================================
# GOOGLE SHEETS SYNC INTERVAL
# ==========================================
# How often to pull data from Google Sheets into PostgreSQL.
# Valid values: 1, 2, 3, 4, 6, 8, 12, 24 (hours). Default: 4
# The original GAS system is not affected — this is read-only from Sheets.
SYNC_INTERVAL_HOURS=4

# ==========================================
# CREDENTIALS NOTE
# ==========================================
# The Google service account key file (credentials.json.json) must be placed
# at: backend/credentials.json.json
# This file is in .gitignore and must NEVER be committed to GitHub.
# When deploying to a server, copy this file manually to the server.
